<UserControl x:Class="Doorpi.UpdateCore.UpdateProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#020309">
    <Grid Background="#020309">
        <Grid.Resources>
            <Style x:Key="ProgressText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#EAF4FF" />
                <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, Arial" />
            </Style>
        </Grid.Resources>

        <Ellipse Width="760" Height="420" Fill="#182D5A" Opacity="0.28"
                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-180,-100,0,0">
            <Ellipse.Effect>
                <BlurEffect Radius="90" />
            </Ellipse.Effect>
        </Ellipse>
        <Ellipse Width="680" Height="520" Fill="#155E75" Opacity="0.22"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-220,-160">
            <Ellipse.Effect>
                <BlurEffect Radius="110" />
            </Ellipse.Effect>
        </Ellipse>

        <Grid MaxWidth="980" Margin="42" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="28" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="30" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="32" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="26" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="EyebrowText"
                       Style="{StaticResource ProgressText}"
                       Text="DOORPI SYSTEM UPDATE"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#7DCBFF"
                       Opacity="0.84" />

            <TextBlock x:Name="TitleText"
                       Grid.Row="2"
                       Style="{StaticResource ProgressText}"
                       Text="Atualizando componentes do sistema..."
                       FontSize="44"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />

            <TextBlock x:Name="StatusText"
                       Grid.Row="4"
                       Style="{StaticResource ProgressText}"
                       Text="Preparando ambiente seguro de atualizacao."
                       FontSize="18"
                       Foreground="#B9C8D8"
                       TextWrapping="Wrap" />

            <Grid Grid.Row="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Height="8" CornerRadius="4" Background="#223044">
                    <Grid x:Name="ProgressTrack" ClipToBounds="True">
                        <Border x:Name="ProgressFill"
                                Width="0"
                                HorizontalAlignment="Left"
                                CornerRadius="4"
                                Background="#EAF4FF" />
                    </Grid>
                </Border>

                <TextBlock x:Name="WarningText"
                           Grid.Row="2"
                           Style="{StaticResource ProgressText}"
                           Text="Nao desligue o sistema durante a atualizacao."
                           FontSize="14"
                           Foreground="#7F90A3"
                           HorizontalAlignment="Right" />
            </Grid>

            <Border Grid.Row="8"
                    Background="#0B1220"
                    BorderBrush="#223044"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18"
                    Opacity="0.92">
                <StackPanel>
                    <TextBlock x:Name="TipLabel"
                               Style="{StaticResource ProgressText}"
                               Text="Notas da versao"
                               FontSize="13"
                               Foreground="#7DCBFF"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="TipText"
                               Margin="0,8,0,0"
                               Style="{StaticResource ProgressText}"
                               Text="A atualizacao esta preparando os arquivos necessarios."
                               FontSize="15"
                               Foreground="#B9C8D8"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
